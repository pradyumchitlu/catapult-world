# Supabase
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# World ID
WORLD_APP_ID=your_world_app_id
WORLD_RP_ID=your_world_rp_id
WORLD_ID_PRIVATE_KEY=your_world_id_private_key
WORLD_ID_ACTION=verify-human

# Auth
JWT_SECRET=veridex-hackathon-secret-change-me
DEV_SKIP_WORLDID_VERIFY=true

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8000/api/auth/github/callback

# Gemini (optional single key for all calls; if unset, chat vs scoring keys below)
# GEMINI_API_KEY=your_gemini_api_key
GEMINI_SCORING_API_KEY=your_gemini_scoring_api_key
GEMINI_CHATBOT_API_KEY=your_gemini_chatbot_api_key
# Server
PORT=8000
FRONTEND_URL=http://localhost:3000
